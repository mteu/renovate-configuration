{
"$schema": "https://docs.renovatebot.com/renovate-schema.json",
"extends": [
	":autodetectRangeStrategy",
	":automergeMinor",
	":automergeRequireAllStatusChecks",
	":combinePatchMinorReleases",
	":enableVulnerabilityAlertsWithLabel(security)",
	":ignoreModulesAndTests",
	":label(dependencies)",
	":prHourlyLimitNone",
	":rebaseStalePrs",
	":semanticCommitsDisabled",
	":separateMajorReleases",
	":widenPeerDependencies",
	"group:recommended"
],
"assignAutomerge": true,
"baseBranches": [
	"main"
],
"commitBodyTable": true,
"commitMessagePrefix": "[TASK]",
"commitMessageTopic": "{{depName}}",
"configMigration": true,
"ignoreUnstable": true,
"labels": [
	"dependencies"
],
"lockFileMaintenance": {
	"automerge": true,
	"automergeType": "pr",
	"commitMessageAction": "Update composer.lock",
	"enabled": true,
	"platformAutomerge": true,
	"recreateClosed": true
},
"packageRules": [
	{
		"description": "Automatically merge minor and patch-level updates",
		"automerge": true,
		"automergeType": "pr",
		"matchUpdateTypes": [
			"minor",
			"patch"
		]
	},
	{
		"description": "Automatically merge minor and patch-level updates by-passing PRs",
		"automerge": true,
		"automergeType": "branch",
		"groupName": "devDependencies",
		"groupSlug": "dev-dependencies",
		"matchDepTypes": ["devDependencies"],
		"matchUpdateTypes": ["patch", "minor"],
		"matchCurrentVersion": "!/^0/"
	},
	{
		"description": "Keep GitHub Actions pinned to commit SHAs and auto-merge non-major updates",
		"matchManagers": ["github-actions"],
		"pinDigests": true,
		"automerge": true,
		"automergeType": "pr",
		"minimumReleaseAge": "3 days",
		"matchUpdateTypes": ["digest", "patch", "minor"]
	},
	{
		"description": "Never auto-merge major GitHub Actions updates",
		"matchManagers": ["github-actions"],
		"matchUpdateTypes": ["major"],
		"automerge": false
	},
	{
		"description": "Don't merge PHP updates",
		"extends": [
			":automergeDisabled"
		],
		"ignoreUnstable": false,
		"matchPackageNames": [
			"php"
		]
	}
],
"platformAutomerge": true,
"prCreation": "immediate",
"rangeStrategy": "update-lockfile",
"separateMinorPatch": true,
"timezone": "Europe/Berlin",
"updateNotScheduled": true,
"vulnerabilityAlerts": {
	"extends": [
		":automergeDisabled",
		":automergePr"
	],
	"rangeStrategy": "replace"
	}
}
